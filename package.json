{
  "name": "evo-app",
  "private": true,
  "packageManager": "pnpm@9.1.3",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "turbo": "^2.5.4"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@evo-app/{backend,frontend}",
    "dev:cron": "npx tsx packages/backend/scripts/local-scheduler.ts",
    "dev:all": "turbo run dev --filter=@evo-app/{backend,frontend} & sleep 3 && npx tsx packages/backend/scripts/local-scheduler.ts & wait",
    "deploy": "turbo run deploy",
    "format": "prettier . --write",
    "lint": "pnpm biome lint --write --unsafe ."
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": false,
    "useTabs": false
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "prettier": "^3.3.3"
  }
}
